{
  "lexicon": 1,
  "id": "systems.gmstn.api.chat.getWorkspaces",
  "defs": {
    "main": {
      "type": "query",
      "description": "Gets the list of chat workspaces that a user belongs to. Does not require auth.",
      "parameters": {
        "type": "params",
        "properties": {
          "identifier": {
            "type": "string",
            "format": "at-identifier",
            "description": "Handle or DID of the account."
          }
        },
        "required": [
          "identifier"
        ]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#workspaces"
        }
      }
    },
    "workspaces": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer"
        },
        "workspaces": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#workspace"
          }
        }
      },
      "required": [
        "count",
        "workspaces"
      ]
    },
    "workspace": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "descriptionLong": {
          "type": "string"
        },
        "descriptionShort": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        },
        "isOwner": {
          "type": "boolean"
        },
        "isAdmin": {
          "type": "boolean"
        },
        "uri": {
          "type": "string",
          "format": "at-uri"
        }
      },
      "required": [
        "name",
        "createdAt",
        "isOwner",
        "isAdmin",
        "uri"
      ]
    }
  }
}
