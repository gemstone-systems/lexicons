{
  "lexicon": 1,
  "id": "systems.gmstn.api.platform.onboarding.getState",
  "defs": {
    "main": {
      "type": "query",
      "description": "Gets the relevant onboarding information for the requesting DID. Requires auth.",
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "#onboardingState"
        }
      }
    },
    "onboardingState": {
      "type": "object",
      "properties": {
        "updatedAt": {
          "type": "string",
          "format": "datetime"
        },
        "chat": {
          "type": "ref",
          "ref": "#onboardingStateObject"
        },
        "projects": {
          "type": "ref",
          "ref": "#onboardingStateObject"
        },
        "knowledge": {
          "type": "ref",
          "ref": "#onboardingStateObject"
        }
      }
    },
    "onboardingStateObject": {
      "type": "object",
      "properties": {
        "onboardedAt": {
          "type": "string",
          "format": "datetime"
        }
      },
      "required": [
        "onboardedAt"
      ]
    }
  }
}
