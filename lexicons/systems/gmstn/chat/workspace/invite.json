{
  "lexicon": 1,
  "id": "systems.gmstn.chat.workspace.invite",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "properties": {
          "recipient": {
            "type": "string",
            "format": "did",
            "description": "The recipient of the invite."
          },
          "workspace": {
            "type": "string",
            "format": "at-uri",
            "description": "The workspace that this invite is for. Must resolve to a systems.gmstn.workspace record."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "The timestamp when this invite was created."
          }
        },
        "required": [
          "recipient",
          "workspace",
          "createdAt"
        ]
      },
      "description": "Record declaring a workspace invite."
    }
  }
}
